# После изменения prisma/schema.prisma: из корня pnpm db:push (или из apps/api: pnpm db:push)
DATABASE_URL="postgresql://atlas:atlas@localhost:5432/atlas_v1?schema=public"
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN="http://localhost:5173"

# Одноразовая загрузка свечей: pnpm run load:candles (из каталога apps/api, нужен DATABASE_URL)
# SYMBOL=BTCUSDT
# SYMBOLS=BTCUSDT,ETHUSDT,HBARUSDT,SUIUSDT,PEPEUSDT
# START_MS=1514764800000

# Ежедневно в 23:55 MSK: tradingDay → таблица CryptoPriceCandle (interval 1d)
# TRADING_DAY_SYMBOLS=BTCUSDT,ETHUSDT,HBARUSDT,SUIUSDT,PEPEUSDT
# TRADING_DAY_CRON_DISABLED=true
