# Скопируйте в docker/.env и подставьте значения.
# Использование: docker compose -f docker-compose.prod.yml --env-file docker/.env up -d --build

POSTGRES_PASSWORD=сгенерируйте_длинный_пароль

JWT_ACCESS_SECRET=сгенерируйте_случайную_строку
JWT_REFRESH_SECRET=другая_случайная_строка

# Порт HTTP снаружи (внутри nginx всегда 80)
HTTP_PORT=8080

# Опционально: если фронт и API на разных доменах — укажите URL фронта
# CORS_ORIGIN=https://app.example.com

# TRADING_DAY_CRON_DISABLED=true
# TRADING_DAY_SYMBOLS=BTCUSDT,ETHUSDT
