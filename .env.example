# Docker: docker compose up -d  →  PostgreSQL :5432, Adminer http://localhost:8080
# (Adminer: System PostgreSQL, Server db, User atlas, Password atlas, DB atlas_v1)

# API (copy to apps/api/.env)
DATABASE_URL="postgresql://atlas:atlas@localhost:5432/atlas_v1?schema=public"
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN="http://localhost:5173"

# Web (copy to apps/web/.env) — в dev можно не задавать: Vite проксирует /api → :3001
# VITE_API_URL="https://your-api.example.com"
